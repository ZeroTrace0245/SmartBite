@page "/payment/thirdparty"
@using computer_project.Web.Services
@inject NavigationManager Navigation
@inject UserSession Session
@rendermode InteractiveServer

<PageTitle>@SelectedMethod Payment</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <!-- Warning Banner -->
            <div class="alert alert-warning d-flex align-items-start gap-3 border-0 shadow-sm mb-4" role="alert">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning flex-shrink-0 mt-1">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/>
                    <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                <div>
                    <strong class="d-block mb-1">⚠️ DEMO MODE - SIMULATION ONLY</strong>
                    <small class="text-muted">This is a demonstration interface mimicking @SelectedMethod. No real payment will be processed.</small>
                </div>
            </div>

            <div class="card border-0 shadow-lg">
                <div class="card-header bg-white border-0 p-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <h4 class="mb-0 fw-bold">@SelectedMethod Payment</h4>
                        @if (SelectedMethod == "Apple Pay")
                        {
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
                            </svg>
                        }
                        else if (SelectedMethod == "Google Pay")
                        {
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="#0070ba">
                                <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516c-.029.186.114.355.304.355h2.677c.457 0 .845-.334.915-.789l.056-.292.904-5.735.058-.315c.071-.455.459-.79.915-.79h.575c3.749 0 6.682-1.523 7.541-5.928.356-1.831.172-3.36-.648-4.441z"/>
                            </svg>
                        }
                    </div>
                </div>

                <div class="card-body p-4">
                    @if (!IsProcessing && !IsComplete)
                    {
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                            <h5 class="mb-3">Connecting to @SelectedMethod...</h5>
                            <p class="text-muted">Please authenticate using your @SelectedMethod account</p>
                            <button class="btn btn-primary btn-lg px-5 mt-3" @onclick="SimulatePayment">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                    <polyline points="22 4 12 14.01 9 11.01"/>
                                </svg>
                                Authenticate & Pay
                            </button>
                        </div>
                    }
                    else if (IsProcessing)
                    {
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <div class="spinner-grow text-success" style="width: 3rem; height: 3rem;" role="status">
                                    <span class="visually-hidden">Processing...</span>
                                </div>
                            </div>
                            <h5 class="mb-3">Processing Payment...</h5>
                            <div class="progress mx-auto" style="max-width: 300px; height: 8px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" role="progressbar" style="width: 100%"></div>
                            </div>
                        </div>
                    }
                    else if (IsComplete)
                    {
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-success">
                                        <polyline points="20 6 9 17 4 12"/>
                                    </svg>
                                </div>
                            </div>
                            <h4 class="mb-3 fw-bold text-success">Payment Successful!</h4>
                            <p class="text-muted mb-4">Your order has been confirmed via @SelectedMethod</p>
                            <div class="alert alert-light border">
                                <small class="text-muted">Redirecting to order tracker...</small>
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-light border-0 p-4 text-center">
                    @if (!IsComplete)
                    {
                        <button class="btn btn-link text-muted" @onclick='() => Navigation.NavigateTo("/shoppinglist")'>
                            ← Cancel and go back
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Method { get; set; }

    private string SelectedMethod => Method ?? "Third Party";
    private bool IsProcessing { get; set; } = false;
    private bool IsComplete { get; set; } = false;

    private async Task SimulatePayment()
    {
        IsProcessing = true;
        await Task.Delay(3000); // Simulate payment processing

        IsProcessing = false;
        IsComplete = true;

        // Store success in session or temp storage
        Session.PaymentCompleted = true;

        await Task.Delay(2000); // Show success message
        Navigation.NavigateTo("/shoppinglist");
    }
}
