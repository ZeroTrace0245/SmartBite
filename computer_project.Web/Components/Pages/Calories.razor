@page "/calories"
@using computer_project.Web.Services
@inject UserSession Session
@rendermode InteractiveServer

<PageTitle>Calories Burned - SmartBite</PageTitle>

<div class="px-md-4 py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <div class="breadcrumb-small mb-1 text-uppercase ls-widest fw-bold opacity-75 text-danger">Gym Focus</div>
            <h1 class="display-6 fw-bold mb-0">Calories Burned</h1>
        </div>
        <button class="btn btn-danger btn-sm shadow px-4 py-2 rounded-3"><i class="bi bi-fire me-2"></i>Log Workout</button>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card p-4 border-0 shadow-sm border-bottom border-danger border-3 h-100">
                <div class="text-muted small fw-bold mb-2 text-uppercase ls-wide">Active Energy</div>
                <div class="display-4 fw-bold mb-2 text-danger">840 <span class="h5 text-muted fw-normal">kcal</span></div>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-danger" style="width: 84%"></div>
                </div>
                <div class="mt-2 text-end small text-muted">Goal: 1000 kcal</div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card p-4 border-0 shadow-sm h-100">
                <h6 class="fw-bold mb-3">Today's Sessions</h6>
                <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-3 border mb-2">
                    <div class="d-flex gap-3 align-items-center">
                        <div class="bg-danger bg-opacity-10 text-danger p-2 rounded"><i class="bi bi-bicycle"></i></div>
                        <div>
                            <div class="fw-bold">Morning Cycling</div>
                            <div class="small text-muted">45 mins • Vigorous</div>
                        </div>
                    </div>
                    <div class="fw-bold text-danger">+420 kcal</div>
                </div>
                <div class="d-flex align-items-center justify-content-between p-3 bg-light rounded-3 border">
                    <div class="d-flex gap-3 align-items-center">
                        <div class="bg-danger bg-opacity-10 text-danger p-2 rounded"><i class="bi bi-boxes"></i></div>
                        <div>
                            <div class="fw-bold">Strength Training: Legs</div>
                            <div class="small text-muted">60 mins • Moderate</div>
                        </div>
                    </div>
                    <div class="fw-bold text-danger">+420 kcal</div>
                </div>
            </div>
        </div>
    </div>
</div>
