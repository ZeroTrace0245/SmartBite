@page "/help-support"
@using computer_project.Web.Models
@using computer_project.Web.Services
@inject SmartBiteApiClient ApiClient
@rendermode InteractiveServer

<PageTitle>Help & Support - SmartBite</PageTitle>

<div class="container py-5 anim-fade-in" style="max-width: 900px;">
    <div class="row g-4">
        <!-- LHS: Knowledge Base / FAQ -->
        <div class="col-lg-5">
            <h2 class="fw-bold mb-3" style="color: #24292f;">Help & Support</h2>
            <p class="text-muted mb-4">Browse our FAQ or ask the SmartBite Support AI for instant help regarding the app's features.</p>

            <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-primary" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Frequently Asked Questions
            </h5>

            <div class="accordion shadow-sm border-0" id="faqAccordion">
                <div class="accordion-item border-0 border-bottom">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                            How do I log a meal?
                        </button>
                    </h2>
                    <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted small">
                            Navigate to the "Log History" page from the side menu and click "+ Add Meal". Enter the meal name and calorie count to save it to your daily log.
                        </div>
                    </div>
                </div>
                <div class="accordion-item border-0 border-bottom">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                            How does the AI Coach work?
                        </button>
                    </h2>
                    <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted small">
                            The AI Coach is powered by GitHub Models. It analyzes your prompts to provide personalized meal plans, macros, and fitness advice.
                        </div>
                    </div>
                </div>
                <div class="accordion-item border-0">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                            Can I export my shopping list?
                        </button>
                    </h2>
                    <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted small">
                            Currently, the shopping list is strictly managed within the app, but you can copy the text or use the Groceries page on your mobile browser.
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 p-4 rounded text-center" style="background-color: #f6f8fa;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-secondary mb-2" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <h6 class="fw-bold mb-1">Still need help?</h6>
                <p class="text-muted small mb-0">Email us at support@smartbite.app</p>
            </div>
        </div>

        <!-- RHS: AI Support Agent -->
        <div class="col-lg-7">
            <div class="card shadow border-0 h-100 d-flex flex-column" style="border-radius: 12px; background-color: #f6f8fa;">
                <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                    <div class="d-flex align-items-center gap-2">
                        <div class="support-icon-bg text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        </div>
                        <h6 class="fw-bold mb-0">SmartBite Support AI</h6>
                    </div>
                    <span class="badge bg-light text-dark border">GitHub Models</span>
                </div>

                <div class="card-body p-4 bg-white d-flex flex-column" style="flex: 1 1 auto; overflow: hidden; min-height: 400px; border-bottom-left-radius: 12px; border-bottom-right-radius: 12px;">

                    @if (!chatMessages.Any())
                    {
                        <div class="text-center my-auto px-3 anim-fade-in text-muted">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-3"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                            <h6>Hello! I'm the SmartBite AI Support Assistant.</h6>
                            <p class="small">How can I help you use the app today?</p>

                            <div class="d-flex flex-wrap justify-content-center gap-2 mt-3">
                                <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick='() => SendQuickPrompt("How do I add items to my shopping list?")'>🛒 Use Shopping List</button>
                                <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick='() => SendQuickPrompt("Where can I find my dietary recommendations?")'>💡 Find Recommendations</button>
                            </div>
                        </div>
                    }

                    <div class="chat-messages mb-3 flex-grow-1" style="overflow-y: auto;">
                        @foreach (var msg in chatMessages)
                        {
                            <div class="d-flex gap-3 mb-3 anim-fade-in @(msg.IsUser ? "justify-content-end" : "")">
                                @if (!msg.IsUser)
                                {
                                    <div class="support-icon-bg text-white rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center shadow-sm" style="width:28px; height:28px; font-size:12px;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                    </div>
                                }
                                <div class="p-3 @(msg.IsUser ? "bg-light border text-dark text-end" : "text-dark")" style="max-width: 85%; border-radius: 8px; @(msg.IsUser ? "border-color: #d0d7de !important; background-color: #f6f8fa !important;" : "background-color: #eef2f5;")">
                                    <div class="small" style="line-height: 1.5; font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;">
                                        @if(msg.IsUser) {
                                            <div style="white-space: pre-wrap;">@msg.Text</div>
                                        } else {
                                            @((MarkupString)Markdig.Markdown.ToHtml(msg.Text))
                                        }
                                    </div>
                                </div>
                                @if (msg.IsUser)
                                {
                                    <div class="bg-secondary text-white rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center shadow-sm" style="width:28px; height:28px; font-size:12px;">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    </div>
                                }
                            </div>
                        }

                        @if (isThinking)
                        {
                            <div class="d-flex gap-3 mb-3 anim-fade-in">
                                <div class="support-icon-bg text-white rounded-circle flex-shrink-0 d-flex align-items-center justify-content-center shadow-sm" style="width:28px; height:28px; font-size:12px;">
                                    <div class="spinner-border spinner-border-sm" role="status" style="width:10px; height:10px; border-width: 1px;"></div>
                                </div>
                                <div class="p-3 text-muted" style="background-color: #eef2f5; border-radius: 8px;">
                                    <div class="small" style="font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;">
                                        Support AI is typing...
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 p-2 rounded" style="background-color: #fff; border: 1px solid #d0d7de;">
                        <input class="form-control border-0 bg-transparent shadow-none" style="font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif; font-size: 0.9rem;" placeholder="Ask anything about using SmartBite..." @bind="userPrompt" @onkeydown="HandleKeyDown" disabled="@isThinking" />
                        <button class="btn btn-dark px-3 fw-bold rounded" @onclick="SendMessage" disabled="@(isThinking || string.IsNullOrWhiteSpace(userPrompt))">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .anim-fade-in {
        animation: fadeIn 0.4s ease-out forwards;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .support-icon-bg {
        background: linear-gradient(135deg, #198754, #20c997);
    }
    /* Hide scrollbar for cleaner UI */
    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }
    .chat-messages::-webkit-scrollbar-thumb {
        background-color: #dee2e6;
        border-radius: 4px;
    }
</style>

@code {
    private bool isThinking = false;
    private string userPrompt = "";
    private List<ChatMessage> chatMessages = new();

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isThinking && !string.IsNullOrWhiteSpace(userPrompt))
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userPrompt) || isThinking) return;

        var question = userPrompt.Trim();
        userPrompt = "";
        chatMessages.Add(new ChatMessage(question, true));
        isThinking = true;
        StateHasChanged();

        try
        {
            // Adding context behind the scenes so the AI acts like a support agent
            var supportContextPrompt = $"You are the official Customer Support AI for an app called SmartBite. Always be polite, concise, and helpful. The user is asking: {question}";
            var response = await ApiClient.GetAICoachAdviceAsync(supportContextPrompt);
            chatMessages.Add(new ChatMessage(response, false));
        }
        catch (Exception ex)
        {
            chatMessages.Add(new ChatMessage($"Sorry, our support systems are currently overwhelmed. Error: {ex.Message}", false));
        }

        isThinking = false;
        StateHasChanged();
    }

    private async Task SendQuickPrompt(string prompt)
    {
        userPrompt = prompt;
        await SendMessage();
    }

    private record ChatMessage(string Text, bool IsUser);
}
