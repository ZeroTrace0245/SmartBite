@using computer_project.Web.Models

@if (IsVisible)
{
    <div class="modal d-block fade-in" style="background: rgba(0,0,0,0.7);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 pb-2">
                    <h5 class="modal-title fw-bold d-flex align-items-center gap-2">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="1" y="4" width="22" height="16" rx="2"/>
                            <line x1="1" y1="10" x2="23" y2="10"/>
                        </svg>
                        Payment Details
                    </h5>
                    <button type="button" class="btn-close" @onclick="Cancel"></button>
                </div>

                @if (!ShowThirdPartyOptions)
                {
                    <!-- Card Payment Form -->
                    <div class="modal-body p-4">
                        <!-- Warning Banner -->
                        <div class="alert alert-warning d-flex align-items-start gap-3 border-0 shadow-sm" role="alert">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-warning flex-shrink-0 mt-1">
                                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                <line x1="12" y1="9" x2="12" y2="13"/>
                                <line x1="12" y1="17" x2="12.01" y2="17"/>
                            </svg>
                            <div>
                                <strong class="d-block mb-1">⚠️ DEMO MODE - DO NOT USE REAL CARDS</strong>
                                <small class="text-muted">This is a demonstration only. Do not enter real debit or credit card information. Use test data only.</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase text-muted">Card Number</label>
                            <input type="text" class="form-control form-control-lg" @bind="CardNumber" placeholder="4532 1234 5678 9010" maxlength="19" @oninput="FormatCardNumber" />
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">Expiration Date</label>
                                <input type="text" class="form-control" @bind="ExpiryDate" placeholder="MM / YY" maxlength="7" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-uppercase text-muted">CV Code</label>
                                <input type="text" class="form-control" @bind="CvCode" placeholder="123" maxlength="4" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-uppercase text-muted">Name on Card</label>
                            <input type="text" class="form-control" @bind="CardholderName" placeholder="JOHN DOE" />
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button class="btn btn-primary btn-lg py-3 fw-bold" @onclick="ProcessCardPayment" disabled="@(!IsCardFormValid)">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Complete Payment
                            </button>
                            <button class="btn btn-success btn-lg py-3 fw-bold" @onclick="ProcessCashPayment">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
                                    <line x1="12" y1="1" x2="12" y2="23"/>
                                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                                </svg>
                                Pay with Cash
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="() => ShowThirdPartyOptions = true">
                                Or use 3rd Party Payment
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Third Party Options -->
                    <div class="modal-body p-4">
                        <p class="text-muted mb-4">Choose your preferred payment method:</p>

                        <div class="d-grid gap-3">
                            <button class="btn btn-outline-dark btn-lg py-3 d-flex align-items-center justify-content-between" @onclick='() => HandleThirdPartySelection("Apple Pay")'>
                                <div class="d-flex align-items-center gap-3">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
                                    </svg>
                                    <span class="fw-bold">Apple Pay</span>
                                </div>
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="9 18 15 12 9 6"/>
                                </svg>
                            </button>

                            <button class="btn btn-outline-dark btn-lg py-3 d-flex align-items-center justify-content-between" @onclick='() => HandleThirdPartySelection("Google Pay")'>
                                <div class="d-flex align-items-center gap-3">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"/>
                                    </svg>
                                    <span class="fw-bold">Google Pay</span>
                                </div>
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="9 18 15 12 9 6"/>
                                </svg>
                            </button>

                            <button class="btn btn-outline-primary btn-lg py-3 d-flex align-items-center justify-content-between" @onclick='() => HandleThirdPartySelection("PayPal")'>
                                <div class="d-flex align-items-center gap-3">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="#0070ba">
                                        <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516c-.029.186.114.355.304.355h2.677c.457 0 .845-.334.915-.789l.056-.292.904-5.735.058-.315c.071-.455.459-.79.915-.79h.575c3.749 0 6.682-1.523 7.541-5.928.356-1.831.172-3.36-.648-4.441z"/>
                                    </svg>
                                    <span class="fw-bold">PayPal</span>
                                </div>
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <polyline points="9 18 15 12 9 6"/>
                                </svg>
                            </button>
                        </div>

                        <button class="btn btn-link text-muted mt-3 w-100" @onclick="() => ShowThirdPartyOptions = false">
                            ← Back to Card Payment
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    .fade-in {
        animation: fadeIn 0.2s ease-in;
    }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnPaymentSuccess { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<string> OnThirdPartySelected { get; set; }

    private bool ShowThirdPartyOptions { get; set; } = false;
    private string CardNumber { get; set; } = "";
    private string ExpiryDate { get; set; } = "";
    private string CvCode { get; set; } = "";
    private string CardholderName { get; set; } = "";

    private bool IsCardFormValid => 
        !string.IsNullOrWhiteSpace(CardNumber) && CardNumber.Length >= 13 &&
        !string.IsNullOrWhiteSpace(ExpiryDate) &&
        !string.IsNullOrWhiteSpace(CvCode) && CvCode.Length >= 3 &&
        !string.IsNullOrWhiteSpace(CardholderName);

    private void FormatCardNumber(ChangeEventArgs e)
    {
        var value = e.Value?.ToString()?.Replace(" ", "") ?? "";
        if (value.Length > 16) value = value.Substring(0, 16);
        
        var formatted = "";
        for (int i = 0; i < value.Length; i++)
        {
            if (i > 0 && i % 4 == 0) formatted += " ";
            formatted += value[i];
        }
        CardNumber = formatted;
    }

    private async Task ProcessCardPayment()
    {
        // Simulate payment processing
        await Task.Delay(1500);
        await OnPaymentSuccess.InvokeAsync();
        ResetForm();
    }

    private async Task ProcessCashPayment()
    {
        // Cash payment - instant confirmation
        await OnPaymentSuccess.InvokeAsync();
        ResetForm();
    }

    private void Cancel()
    {
        ResetForm();
        OnCancel.InvokeAsync();
    }

    private async Task HandleThirdPartySelection(string method)
    {
        await OnThirdPartySelected.InvokeAsync(method);
        ResetForm();
    }

    private void ResetForm()
    {
        CardNumber = "";
        ExpiryDate = "";
        CvCode = "";
        CardholderName = "";
        ShowThirdPartyOptions = false;
    }
}
