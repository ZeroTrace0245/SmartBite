@code {
    private HealthReport? report;
    private UserGoal? goal;
    private double totalWater;
    private List<Meal> recentMealsList = new();
    private bool showShareOptions = false;

    private string predictiveInsight = "";
    private bool isLoadingInsights = false;
    private bool isNotificationsEnabled = false;

    private async Task EnableNotifications()
    {
        var status = await JS.InvokeAsync<string>("requestNotificationPermission");
        if (status == "granted")
        {
            isNotificationsEnabled = true;
            await JS.InvokeVoidAsync("showNotification", "Welcome to SmartBite Reminders!", new { body = "We'll ping you when it's time to log a meal or drink water." });
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Notification permissions were not granted.");
        }
    }

    private async Task ScheduleTestReminder()
    {
        if (!isNotificationsEnabled)
        {
            await JS.InvokeVoidAsync("alert", "Please enable reminders first.");
            return;
        }

        _ = Task.Delay(5000).ContinueWith(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await JS.InvokeVoidAsync("showNotification", "Hydration Reminder!", new { body = "It's been a while since your last log. Time to drink a glass of water!" });
            });
        });
    }

    private async Task LoadPredictiveInsights()
    {
        if (report == null || recentMealsList == null) return;

        var chatClient = Provider.GetService<ChatClient>();
        if (chatClient == null)
        {
            await JS.InvokeVoidAsync("alert", "AI ChatClient not configured. Please add GitHubToken to user secrets.");
            return;
        }

        isLoadingInsights = true;
        StateHasChanged();
        try
        {
            var mealSummaries = string.Join("\n", recentMealsList.Take(5).Select(m => $"- {m.Name}: {m.Calories} kcal"));
            var prompt = $$"""
                You are a predictive health analytics engine. Analyze the user's data context:
                Daily Total Calories: {{report.TotalCalories}}
                Protein: {{report.Protein}}g, Carbs: {{report.Carbs}}g
                Recent Meals Logged:
                {{mealSummaries}}

                Predict a trend or habit, and provide ONE single sentence of proactive, customized advice. Examples: 
                - "You usually miss your protein goal on workout days; prep a shake tonight."
                - "Your dinners are heavy in carbs; balance them with healthy fats."
                Wait, output ONLY the single sentence insight. No conversational intro.
                """;

            var response = await chatClient.CompleteChatAsync(prompt);
            predictiveInsight = response.Value.Content[0].Text?.Trim() ?? "Keep up the great work!";
        }
        catch (Exception)
        {
            predictiveInsight = "Unable to analyze patterns at this time. Log more data.";
        }
        finally
        {
            isLoadingInsights = false;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var reportTask = ApiClient.GetReportAsync().ContinueWith(t => t.IsFaulted ? new HealthReport
        {
            UserId = 1,
            Summary = "AI summary unavailable — start AI Foundry Local for insights.",
            GeneratedAt = DateTime.UtcNow
        } : t.Result, TaskContinuationOptions.ExecuteSynchronously);

        var goalTask = ApiClient.GetGoalAsync(1);
        var waterTask = ApiClient.GetWaterIntakesAsync();
        var mealsTask = ApiClient.GetMealsAsync();

        await Task.WhenAll(reportTask, goalTask, waterTask, mealsTask);

        report = await reportTask;
        try { goal = await goalTask; } catch { }
        try
        {
            var waterLogs = await waterTask;
            totalWater = waterLogs.Where(i => i.LoggedAt.Date == DateTime.UtcNow.Date).Sum(i => i.Amount);
        }
        catch { }
        try { recentMealsList = await mealsTask ?? new(); } catch { }
    }

    private double GetPercent(double val, double target) => target > 0 ? Math.Min(100, (val / target) * 100) : 0;

    private double GetMacroPct(double p, double c, double f, string type)
    {
        double total = p + c + f;
        if (total == 0) return 33.3; 
        return type switch
        {
            "protein" => (p / total) * 100,
            "carbs" => (c / total) * 100,
            "fat" => (f / total) * 100,
            _ => 0
        };
    }
}

