@page "/nutrient-score"
@using computer_project.Web.Services
@inject UserSession Session
@rendermode InteractiveServer

<PageTitle>Nutrient Score - SmartBite</PageTitle>

<div class="px-md-4 py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <div class="breadcrumb-small mb-1 text-uppercase ls-widest fw-bold opacity-75 text-success">Diet Focus</div>
            <h1 class="display-6 fw-bold mb-0">Micronutrient Report</h1>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-5">
            <div class="card p-4 border-0 shadow-sm border-bottom border-success border-3 h-100 text-center d-flex flex-column justify-content-center">
                <div class="text-muted small fw-bold mb-3 text-uppercase ls-wide">Overall Diet Quality</div>
                <div class="display-1 fw-bold text-success mb-2">A-</div>
                <p class="small text-muted px-3">Based on vitamin compliance, variety of foods, and processed sugar restrictions over the last 7 days.</p>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card p-4 border-0 shadow-sm h-100">
                <h6 class="fw-bold mb-4">Key Vitamin Targets</h6>
                <div class="mb-3">
                    <div class="d-flex justify-content-between small fw-bold mb-1">
                        <span>Vitamin D</span>
                        <span class="text-success">Ideal Range (90%)</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 90%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between small fw-bold mb-1">
                        <span>Iron</span>
                        <span class="text-warning">Slightly Low (65%)</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-warning" style="width: 65%"></div>
                    </div>
                    <div class="text-muted small mt-1" style="font-size:0.7rem;">Suggested Action: Incorporate more Spinach or Lean Meats</div>
                </div>
                <div class="mb-0">
                    <div class="d-flex justify-content-between small fw-bold mb-1">
                        <span>Vitamin C</span>
                        <span class="text-success">Optimal (100%)</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 100%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>