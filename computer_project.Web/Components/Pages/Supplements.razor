@page "/supplements"
@using computer_project.Web.Services
@inject UserSession Session
@rendermode InteractiveServer

<PageTitle>Supplements - SmartBite</PageTitle>

<div class="px-md-4 py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <div class="breadcrumb-small mb-1 text-uppercase ls-widest fw-bold opacity-75 text-danger">Gym Focus</div>
            <h1 class="display-6 fw-bold mb-0">Supplement Stack</h1>
        </div>
        <button class="btn btn-outline-danger btn-sm shadow-sm px-4 py-2 rounded-3"><i class="bi bi-plus-lg me-2"></i>Add Supp</button>
    </div>

    <div class="card p-4 border-0 shadow-sm border-bottom border-danger border-3 mb-4">
        <h5 class="fw-bold mb-4">Today's Schedule</h5>
        <div class="list-group list-group-flush">
            <label class="list-group-item d-flex gap-3 py-3 align-items-center">
                <input class="form-check-input flex-shrink-0 fs-4 text-danger border-danger" type="checkbox" checked disabled>
                <div class="d-flex gap-3 w-100 justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-bold">Pre-Workout (C4)</h6>
                        <small class="text-muted">1 Scoop • 7:00 AM</small>
                    </div>
                </div>
            </label>
            <label class="list-group-item d-flex gap-3 py-3 align-items-center">
                <input class="form-check-input flex-shrink-0 fs-4 text-danger border-danger" type="checkbox" checked disabled>
                <div class="d-flex gap-3 w-100 justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-bold">Protein Shake (Whey)</h6>
                        <small class="text-muted">1.5 Scoops • Post Workout</small>
                    </div>
                </div>
            </label>
            <label class="list-group-item d-flex gap-3 py-3 align-items-center bg-light rounded mt-2 border">
                <input class="form-check-input flex-shrink-0 fs-4 text-danger border-danger" type="checkbox" value="">
                <div class="d-flex gap-3 w-100 justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-bold">Creatine Monohydrate</h6>
                        <small class="text-muted">5g • Post Workout Window</small>
                    </div>
                    <span class="badge bg-danger rounded-pill">Pending</span>
                </div>
            </label>
            <label class="list-group-item d-flex gap-3 py-3 align-items-center bg-light rounded mt-2 border">
                <input class="form-check-input flex-shrink-0 fs-4 text-danger border-danger" type="checkbox" value="">
                <div class="d-flex gap-3 w-100 justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-bold">Daily Multivitamin</h6>
                        <small class="text-muted">1 Tablet • With Dinner</small>
                    </div>
                    <span class="badge bg-danger rounded-pill">Upcoming</span>
                </div>
            </label>
        </div>
    </div>
</div>
