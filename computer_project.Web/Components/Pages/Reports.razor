@page "/reports"
@using computer_project.Web.Models
@using OpenAI.Chat
@using Microsoft.Extensions.DependencyInjection
@using System.Text.Json
@inject SmartBiteApiClient ApiClient
@inject IJSRuntime JS
@inject IServiceProvider Provider
@rendermode InteractiveServer

<PageTitle>Health Reports</PageTitle>

<ConsumerOnly>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Performance & Analytics</h1>
            <p class="text-muted">Analyze your progress and export your health data.</p>
        </div>
        <button class="btn btn-dark shadow-sm d-flex align-items-center gap-2 px-4 py-2 rounded-pill glow-btn" @onclick="ExtractCSV">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span>Extract (CSV)</span>
        </button>
    </div>

    @if (report == null || meals == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Analyzing your data...</p>
        </div>
    }
    else
    {
        <div class="row g-4 mb-4">
            <div class="col-md-12">
                <div class="card border-0 shadow-sm mica-effect">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <h5 class="fw-bold mb-0">Daily Summary - @report.GeneratedAt.ToShortDateString()</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row text-center g-4">
                            <div class="col-md-3">
                                <div class="p-3 bg-light bg-opacity-10 rounded-4">
                                    <div class="text-muted small text-uppercase fw-bold mb-1">Calories</div>
                                    <div class="h3 fw-bold mb-0 text-primary">@report.TotalCalories.ToString("N0")</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 bg-light bg-opacity-10 rounded-4">
                                    <div class="text-muted small text-uppercase fw-bold mb-1">Protein</div>
                                    <div class="h3 fw-bold mb-0 text-success">@report.Protein.ToString("N1")g</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 bg-light bg-opacity-10 rounded-4">
                                    <div class="text-muted small text-uppercase fw-bold mb-1">Carbs</div>
                                    <div class="h3 fw-bold mb-0 text-info">@report.Carbs.ToString("N1")g</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="p-3 bg-light bg-opacity-10 rounded-4">
                                    <div class="text-muted small text-uppercase fw-bold mb-1">Fat</div>
                                    <div class="h3 fw-bold mb-0 text-warning">@report.Fat.ToString("N1")g</div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold mb-0 text-primary">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                                    AI Health Insights
                                </h6>
                                <button class="btn btn-sm btn-outline-primary" @onclick="GenerateAiTips" disabled="@isLoadingAi">
                                    @if (isLoadingAi) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                    Analyze My Data
                                </button>
                            </div>
                            <div class="row g-3">
                                @if (tips.Count == 0 && !isLoadingAi)
                                {
                                    <div class="col-12 text-center text-muted small py-3">
                                        Click "Analyze My Data" to generate personalized feedback based on your recent meals.
                                    </div>
                                }
                                @foreach (var tip in tips)
                                {
                                    <div class="col-md-4">
                                        <div class="p-3 h-100 bg-primary bg-opacity-10 border border-primary border-opacity-10 rounded-3">
                                            <div class="d-flex gap-2">
                                                <i class="bi bi-lightbulb-fill text-primary mt-1"></i>
                                                <p class="mb-0 small fw-semibold">@tip</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent border-0 pt-4 px-4">
                        <h5 class="fw-bold mb-0">Recent Meals Log</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light bg-opacity-50">
                                    <tr class="small text-muted text-uppercase">
                                        <th class="ps-4">Meal Name</th>
                                        <th>Calories</th>
                                        <th>Protein</th>
                                        <th>Carbs</th>
                                        <th>Fat</th>
                                        <th class="pe-4">Logged At</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var meal in meals.Take(10))
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold">@meal.Name</td>
                                            <td>@meal.Calories kcal</td>
                                            <td>@meal.Protein g</td>
                                            <td>@meal.Carbs g</td>
                                            <td>@meal.Fat g</td>
                                            <td class="pe-4 text-muted small">@meal.LoggedAt.ToString("g")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</ConsumerOnly>

@code {
    private HealthReport? report;
    private List<Meal>? meals;
    private List<string> tips = new();
    private bool isLoadingAi = false;

    private class AiTipsData
    {
        public List<string> Suggestions { get; set; } = new();
    }

    protected override async Task OnInitializedAsync()
    {
        report = await ApiClient.GetReportAsync();
        meals = await ApiClient.GetMealsAsync();
    }

    private async Task GenerateAiTips()
    {
        if (report == null || meals == null) return;

        var chatClient = Provider.GetService<ChatClient>();
        if (chatClient == null)
        {
            await JS.InvokeVoidAsync("alert", "AI ChatClient not configured. Please add GitHubToken to user secrets.");
            return;
        }

        isLoadingAi = true;
        try
        {
            var mealSummaries = string.Join("\n", meals.Take(10).Select(m => $"- {m.Name}: {m.Calories} kcal (P: {m.Protein}g, C: {m.Carbs}g, F: {m.Fat}g)"));

            var prompt = $$"""
                You are an expert fitness and nutrition coach. Here is the user's daily summary:
                Calories: {{report.TotalCalories}}
                Protein: {{report.Protein}}g
                Carbs: {{report.Carbs}}g
                Fat: {{report.Fat}}g

                And their recent meals:
                {{mealSummaries}}

                Provide exactly 3 concise, actionable, and personalized suggestions to improve their diet, hit their goals, or recover better.
                Respond ONLY with a valid JSON object matching this schema. Do not include markdown codeblocks or any backticks:
                {
                  "Suggestions": [
                    "Short tip 1...",
                    "Short tip 2...",
                    "Short tip 3..."
                  ]
                }
                """;

            var response = await chatClient.CompleteChatAsync(prompt);
            var jsonString = response.Value.Content[0].Text?.Trim();

            if (!string.IsNullOrEmpty(jsonString))
            {
                if (jsonString.StartsWith("```json"))
                {
                    jsonString = jsonString.Substring(7);
                    if (jsonString.EndsWith("```")) jsonString = jsonString.Substring(0, jsonString.Length - 3);
                }
                else if (jsonString.StartsWith("```"))
                {
                    jsonString = jsonString.Substring(3);
                    if (jsonString.EndsWith("```")) jsonString = jsonString.Substring(0, jsonString.Length - 3);
                }

                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var data = JsonSerializer.Deserialize<AiTipsData>(jsonString.Trim(), options);

                if (data != null && data.Suggestions != null)
                {
                    tips = data.Suggestions;
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Failed to generate insights: {ex.Message}");
        }
        finally
        {
            isLoadingAi = false;
        }
    }

    private async Task ExtractCSV()
    {
        if (meals == null || report == null) return;

        var csv = new System.Text.StringBuilder();
        csv.AppendLine("Type,Name,Calories,Protein,Carbs,Fat,Date");
        csv.AppendLine($"Summary,Daily Total,{report.TotalCalories},{report.Protein},{report.Carbs},{report.Fat},{report.GeneratedAt:yyyy-MM-dd}");

        foreach (var meal in meals)
        {
            csv.AppendLine($"Meal,{meal.Name},{meal.Calories},{meal.Protein},{meal.Carbs},{meal.Fat},{meal.LoggedAt:yyyy-MM-dd HH:mm}");
        }

        await JS.InvokeVoidAsync("downloadFile", $"SmartBite_Export_{DateTime.Now:yyyyMMdd}.csv", csv.ToString());
    }
}

