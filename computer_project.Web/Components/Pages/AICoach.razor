@page "/ai"
@using computer_project.Web.Models
@using computer_project.Web.Services
@inject SmartBiteApiClient ApiClient
@inject UserSession Session
@rendermode InteractiveServer

<PageTitle>AI Coach - SmartBite</PageTitle>

<ConsumerOnly>
    <style>
        .chat-anim {
            animation: slideUpFade 0.4s ease-out forwards;
        }
        @@keyframes slideUpFade {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .coach-icon-bg {
            background: linear-gradient(135deg, #6f42c1, #007bff);
        }
    </style>
    <div class="container py-4 d-flex flex-column" style="max-width: 800px; min-height: 80vh;">
        @if (!chatMessages.Any())
        {
            <div class="d-flex flex-column align-items-center justify-content-center flex-grow-1 chat-anim mb-5 mt-5">
                <div class="mb-3">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-primary" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                </div>
                <h1 class="h3 fw-bold mb-2" style="color: #24292f;">SmartBite AI Coach</h1>
                <p class="text-muted mb-4">Powered by <strong>GitHub Models</strong> (Aspire + MEAI)</p>

                <div class="w-100 mb-5" style="max-width: 600px;">
                    <div class="d-flex gap-2 p-2 rounded shadow-sm" style="background-color: #fff; border: 1px solid #d0d7de;">
                        <input class="form-control border-0 bg-transparent shadow-none" style="font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;" placeholder="Ask a health or nutrition question..." @bind="userPrompt" @onkeydown="HandleKeyDown" disabled="@isThinking" />
                        <button class="btn btn-primary px-4 fw-bold" @onclick="SendMessage" disabled="@(isThinking || string.IsNullOrWhiteSpace(userPrompt))">
                            Prompt
                        </button>
                    </div>
                </div>

                @* --- Quick Action Pathways --- *@
                <div class="row g-3 w-100">
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-0" style="background-color: #f6f8fa; cursor: pointer; transition: transform 0.2s, background-color 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'" @onclick='() => SendQuickPrompt("Generate a 7-day meal plan tailored for my diet. Include daily macro targets (calories, protein, carbs, fat), exact portion sizes, and a summarized grocery list for the week.")'>
                            <div class="card-body text-center p-3">
                                <div class="mb-2 text-primary">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
                                </div>
                                <h6 class="fw-bold mb-1 text-dark" style="font-size: 0.9rem;">Diet Plan</h6>
                                <p class="text-muted small mb-0" style="font-size: 0.75rem;">Generate meal plans, macros & grocery lists.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-0" style="background-color: #f6f8fa; cursor: pointer; transition: transform 0.2s, background-color 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'" @onclick='() => SendQuickPrompt("Create a personalized workout routine. Include strength and endurance exercises, target calories to burn, recommended rest protocols, and tips for progressive overload.")'>
                            <div class="card-body text-center p-3">
                                <div class="mb-2 text-danger">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 11.23-.42.42a4.99 4.99 0 0 0-1.46 3.53C16.12 18 18.5 20.38 21 20.38a3.1 3.1 0 0 0 0-6.19c-.31 0-.62.04-.92.11L21 11.5a13.9 13.9 0 0 0-3-4.5"/><path d="m6 11.23.42.42a4.99 4.99 0 0 1 1.46 3.53C7.88 18 5.5 20.38 3 20.38a3.1 3.1 0 0 1 0-6.19A3.08 3.08 0 0 1 3.92 14.3L3 11.5a13.9 13.9 0 0 1 3-4.5"/><path d="M14.5 5.5a2.5 2.5 0 0 0-5 0v3.5a2.5 2.5 0 0 0 5 0z"/></svg>
                                </div>
                                <h6 class="fw-bold mb-1 text-dark" style="font-size: 0.9rem;">Gym Routine</h6>
                                <p class="text-muted small mb-0" style="font-size: 0.75rem;">Get personalized workouts & performance tips.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-0" style="background-color: #f6f8fa; cursor: pointer; transition: transform 0.2s, background-color 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'" @onclick='() => SendQuickPrompt("Create a balanced holistic wellness plan for me. Include hydration targets, sleep hygiene tips, step goals, and balanced meal suggestions without strict diet rules.")'>
                            <div class="card-body text-center p-3">
                                <div class="mb-2 text-success">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                </div>
                                <h6 class="fw-bold mb-1 text-dark" style="font-size: 0.9rem;">General Wellness</h6>
                                <p class="text-muted small mb-0" style="font-size: 0.75rem;">Build a simple daily routine & healthy habits.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            @* --- Chat Interface --- *@
            <div class="card shadow-sm chat-anim flex-grow-1 d-flex flex-column" style="border-color: #d0d7de !important; background-color: #f6f8fa;">
                <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between" style="border-color: #d0d7de !important;">
                    <h6 class="fw-bold mb-0 d-flex align-items-center" style="color: #24292f;">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-primary me-2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                        SmartBite AI Coach
                    </h6>
                    <span class="badge bg-light text-dark border">GitHub Models</span>
                </div>
                <div class="card-body p-4 bg-white d-flex flex-column" style="border-bottom-left-radius: var(--bs-card-border-radius); border-bottom-right-radius: var(--bs-card-border-radius); flex: 1 1 auto; overflow: hidden;">
                    <div class="chat-messages mb-4 flex-grow-1" style="overflow-y: auto;">
                        @foreach (var msg in chatMessages)
                        {
                            <div class="d-flex gap-3 mb-3 chat-anim @(msg.IsUser ? "justify-content-end" : "")">
                                @if (!msg.IsUser)
                                {
                                    <div class="coach-icon-bg text-white rounded flex-shrink-0 d-flex align-items-center justify-content-center shadow-sm" style="width:32px; height:32px; font-size:14px;">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/></svg>
                                    </div>
                                }
                                <div class="p-3 @(msg.IsUser ? "bg-light border text-dark text-end" : "text-dark")" style="max-width: 80%; border-radius: 6px; @(msg.IsUser ? "border-color: #d0d7de !important; background-color: #f6f8fa !important;" : "")">
                                    <div class="small" style="line-height: 1.5; font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;">
                                        @if(msg.IsUser) {
                                            <div style="white-space: pre-wrap;">@msg.Text</div>
                                        } else {
                                            @((MarkupString)Markdig.Markdown.ToHtml(msg.Text))
                                        }
                                    </div>
                                </div>
                                @if (msg.IsUser)
                                {
                                    <div class="bg-secondary text-white rounded flex-shrink-0 d-flex align-items-center justify-content-center" style="width:32px; height:32px; font-size:14px;">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    </div>
                                }
                            </div>
                        }

                        @if (isThinking)
                        {
                            <div class="d-flex gap-3 mb-3 chat-anim">
                                <div class="coach-icon-bg text-white rounded flex-shrink-0 d-flex align-items-center justify-content-center shadow-sm" style="width:32px; height:32px; font-size:14px;">
                                    <div class="spinner-border spinner-border-sm" role="status" style="width:12px; height:12px; border-width: 1px;"></div>
                                </div>
                                <div class="p-3 text-muted">
                                    <div class="small" style="font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;">
                                        Fetching advice from GitHub Models...
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-2 p-2 rounded chat-anim" style="background-color: #f6f8fa; border: 1px solid #d0d7de;">
                        <input class="form-control border-0 bg-transparent shadow-none" style="font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;" placeholder="Ask a health or nutrition question..." @bind="userPrompt" @onkeydown="HandleKeyDown" disabled="@isThinking" />
                        <button class="btn btn-primary px-4 fw-bold" @onclick="SendMessage" disabled="@(isThinking || string.IsNullOrWhiteSpace(userPrompt))">
                            Prompt
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</ConsumerOnly>

@code {
    private bool isThinking = false;
    private string userPrompt = "";
    private List<ChatMessage> chatMessages = new();

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isThinking && !string.IsNullOrWhiteSpace(userPrompt))
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userPrompt) || isThinking) return;

        var question = userPrompt.Trim();
        userPrompt = "";
        chatMessages.Add(new ChatMessage(question, true));
        isThinking = true;
        StateHasChanged();

        try
        {
            var response = await ApiClient.GetAICoachAdviceAsync(question);
            chatMessages.Add(new ChatMessage(response, false));
        }
        catch (Exception ex)
        {
            chatMessages.Add(new ChatMessage($"Could not reach AI. Error: {ex.Message}", false));
        }

        isThinking = false;
        StateHasChanged();
    }

    private async Task SendQuickPrompt(string prompt)
    {
        userPrompt = prompt;
        await SendMessage();
    }

    private record ChatMessage(string Text, bool IsUser);
}
