@page "/login"
@using computer_project.Web.Models
@using computer_project.Web.Services
@inject SmartBiteApiClient ApiClient
@inject NavigationManager Navigation
@inject UserSession Session
@rendermode InteractiveServer

<PageTitle>Sign In - SmartBite</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="mx-auto mb-3 bg-secondary bg-opacity-10 rounded-circle border d-flex align-items-center justify-content-center shadow-sm" style="width: 80px; height: 80px;">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-secondary"><circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
                    </div>
                    <h4 class="fw-bold fs-4">@(string.IsNullOrWhiteSpace(username) ? "Welcome Back" : username)</h4>
                    <p class="text-muted small">Sign in to your health journey</p>
                </div>

                <div class="input-group mb-3 shadow-sm rounded-3 overflow-hidden">
                    <span class="input-group-text bg-white border-end-0">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </span>
                    <input class="form-control border-start-0 ps-0" @bind="username" @bind:event="oninput" placeholder="Username" />
                </div>

                <div class="input-group mb-4 shadow-sm rounded-3 overflow-hidden">
                    <span class="input-group-text bg-white border-end-0" title="PIN">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted"><rect x="3" y="3" width="6" height="6" rx="1"/><rect x="15" y="3" width="6" height="6" rx="1"/><rect x="15" y="15" width="6" height="6" rx="1"/><rect x="3" y="15" width="6" height="6" rx="1"/></svg>
                    </span>
                    <input type="password" class="form-control border-start-0 ps-0" @bind="password" placeholder="PIN / Password" />
                </div>

                <label class="form-label small fw-bold text-muted text-uppercase mb-2 d-block text-center mt-4" style="letter-spacing: 1px;">Selected Pathway</label>
                <div class="row g-2 mb-4">
                    <div class="col-4">
                        <button type="button" class="btn w-100 p-2 h-100 d-flex flex-column align-items-center @(pathway == "Gym" ? "btn-danger shadow-sm border-danger" : "btn-light border text-muted hover-up")" @onclick="@(() => pathway = "Gym")">
                            <svg width="24" height="24" class="mb-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 5v14M18 5v14M2 8h4M2 16h4M18 8h4M18 16h4M10 12h4"/></svg>
                            <span class="small fw-bold mt-1" style="font-size: 0.7rem;">Gym</span>
                        </button>
                    </div>
                    <div class="col-4">
                        <button type="button" class="btn w-100 p-2 h-100 d-flex flex-column align-items-center @(pathway == "Diet" ? "btn-success shadow-sm border-success" : "btn-light border text-muted hover-up")" @onclick="@(() => pathway = "Diet")">
                            <svg width="24" height="24" class="mb-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v2M12 22v-2M5 12H3M21 12h-2M18.364 5.636l-1.414 1.414M7.05 16.95l-1.414 1.414M18.364 18.364l-1.414-1.414M7.05 7.05L5.636 5.636M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                            <span class="small fw-bold mt-1" style="font-size: 0.7rem;">Diet</span>
                        </button>
                    </div>
                    <div class="col-4">
                        <button type="button" class="btn w-100 p-2 h-100 d-flex flex-column align-items-center @(pathway == "General" ? "btn-primary shadow-sm border-primary" : "btn-light border text-muted hover-up")" @onclick="@(() => pathway = "General")">
                            <svg width="24" height="24" class="mb-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a5 5 0 0 0-7.08-7.08L12 6.32l-1.16-1.16a5 5 0 0 0-7.08 7.08l1.16 1.16L12 21.24l7.08-7.08 1.16-1.16z"/></svg>
                            <span class="small fw-bold mt-1" style="font-size: 0.7rem;">General</span>
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2 small">@errorMessage</div>
                }

                <button class="btn btn-primary w-100 py-2 fw-bold" @onclick="HandleLogin" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Sign In
                </button>

                <div class="text-center mt-4">
                    <span class="text-muted small">Don't have an account?</span>
                    <a href="register" class="small fw-bold ms-1">Create one</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private string pathway = "General";
    private string? errorMessage;
    private bool isSubmitting = false;

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please fill in all fields.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;

        try
        {
            var user = await ApiClient.LoginAsync(username, password);
            if (user != null)
            {
                user.Pathway = pathway; // Use local selection
                Session.Login(user);
                Navigation.NavigateTo("/dashboard");
            }
            else
            {
                errorMessage = "Invalid username or password.";
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
