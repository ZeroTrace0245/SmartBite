@page "/protein"
@using computer_project.Web.Services
@inject UserSession Session
@rendermode InteractiveServer

<PageTitle>Protein Tracking - SmartBite</PageTitle>

<div class="px-md-4 py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <div class="breadcrumb-small mb-1 text-uppercase ls-widest fw-bold opacity-75 text-success">Diet Focus</div>
            <h1 class="display-6 fw-bold mb-0">Protein Tracking</h1>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-5">
            <div class="card p-4 border-0 shadow-sm border-bottom border-success border-3 h-100">
                <div class="text-muted small fw-bold mb-2 text-uppercase ls-wide">Daily Protein Goal</div>
                <div class="display-3 fw-bold mb-2 text-success">142 <span class="h5 text-muted fw-normal">g</span></div>
                <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-success" style="width: 82%"></div>
                </div>
                <div class="mt-2 text-end small text-muted">Target: 170g</div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card p-4 border-0 shadow-sm h-100 bg-success text-white">
                <h5 class="fw-bold mb-4"><i class="bi bi-egg-fried me-2"></i>High Protein Sources Today</h5>
                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom border-white border-opacity-25 pb-2">
                    <span class="fw-bold">Chicken Breast (8oz)</span>
                    <span>54g</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom border-white border-opacity-25 pb-2">
                    <span class="fw-bold">Greek Yogurt</span>
                    <span>18g</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom border-white border-opacity-25 pb-2">
                    <span class="fw-bold">Protein Shake (1 Scoop)</span>
                    <span>25g</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">3 Scrambled Eggs</span>
                    <span>18g</span>
                </div>
            </div>
        </div>
    </div>
</div>
