    private List<ShoppingListItem>? items;
    private string newItemName = "";
    private bool showPaymentModal = false;
    private bool isExportingCart = false;
    private string aiGoalInput = "I need to lose weight";
    private bool isGeneratingAiSuggestions = false;
    private string aiSuggestionMessage = "";
    private List<string> aiSuggestedItems = new();

    private async Task ExportToInstacart()
    {
        if (items == null || !items.Any(i => !i.IsPurchased))
        {
            await JS.InvokeVoidAsync("alert", "Add some unpurchased items to your list first!");
            return;
        }

        isExportingCart = true;
        await InvokeAsync(StateHasChanged);

        // Simulate API call to Instacart/Walmart
        await Task.Delay(2000);

        var unpurchased = items.Where(i => !i.IsPurchased).Select(i => i.ItemName).ToList();

        isExportingCart = false;
        await InvokeAsync(StateHasChanged);

        await JS.InvokeVoidAsync("alert", $"Successfully added {unpurchased.Count} items to your Instacart cart:\n\n{string.Join(", ", unpurchased)}\n\n(This is a demo feature)");
    }

    private async Task GenerateAIGrocerySuggestions()
    {
        aiSuggestionMessage = string.Empty;

        var goalText = string.IsNullOrWhiteSpace(aiGoalInput) ? "I need to lose weight" : aiGoalInput.Trim();
        var chatClient = Provider.GetService<ChatClient>();
        if (chatClient == null)
        {
            await JS.InvokeVoidAsync("alert", "AI ChatClient not configured. Please add GitHubToken to user secrets.");
            return;
        }

        isGeneratingAiSuggestions = true;
        try
        {
            var availableItems = string.Join(", ", groceryDatabase.Select(g => g.Name));
            var prompt = $$"""
                You are a grocery recommendation assistant.
                User goal: "{{goalText}}"

                Recommend exactly 5 grocery items from this allowed list:
                {{availableItems}}

                Respond ONLY with a valid JSON object matching this schema. Do not include markdown codeblocks or any backticks.
                {
                  "Items": ["Item 1", "Item 2", "Item 3", "Item 4", "Item 5"]
                }
                """;

            var response = await chatClient.CompleteChatAsync(prompt);
            var jsonString = response.Value.Content[0].Text?.Trim();

            if (string.IsNullOrWhiteSpace(jsonString))
            {
                aiSuggestionMessage = "Could not generate suggestions right now.";
                return;
            }

            if (jsonString.StartsWith("```json"))
            {
                jsonString = jsonString.Substring(7);
                if (jsonString.EndsWith("```")) jsonString = jsonString.Substring(0, jsonString.Length - 3);
            }
            else if (jsonString.StartsWith("```"))
            {
                jsonString = jsonString.Substring(3);
                if (jsonString.EndsWith("```")) jsonString = jsonString.Substring(0, jsonString.Length - 3);
            }

            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var data = JsonSerializer.Deserialize<AiGroceryData>(jsonString.Trim(), options);

            if (data?.Items == null || data.Items.Count == 0)
            {
                aiSuggestionMessage = "Could not generate suggestions right now.";
                return;
            }

            aiSuggestedItems = data.Items
                .Select(i => i.Trim())
                .Where(i => !string.IsNullOrWhiteSpace(i))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            aiSuggestionMessage = "Suggestions refreshed. Click any item to add it manually in the input.";
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Failed to generate grocery suggestions: {ex.Message}");
        }
        finally
        {
            isGeneratingAiSuggestions = false;
        }
    }

    private GroceryItemData? SuggestionForCurrentItem => GetItemMacros(newItemName);

    private GroceryItemData? GetItemMacros(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return null;
        return groceryDatabase.FirstOrDefault(g => name.Contains(g.Name, StringComparison.OrdinalIgnoreCase));
    }

