    private double TotalProtein => items?.Where(i => !i.IsPurchased).Sum(i => GetItemMacros(i.ItemName)?.Protein ?? 0) ?? 0;
    private double TotalCalories => items?.Where(i => !i.IsPurchased).Sum(i => GetItemMacros(i.ItemName)?.Calories ?? 0) ?? 0;

