        new GroceryItemData { Name = "Olive Oil", Calories = 884, Protein = 0, Carbs = 0, Fat = 100, Price = 8.0, PathwayRecommendation = "General" },

        // Gym Members (High Protein, Recovery, Hydration)
        new GroceryItemData { Name = "Chicken Breast", Calories = 165, Protein = 31, Carbs = 0, Fat = 3.6, Price = 6.0, PathwayRecommendation = "Gym" },
        new GroceryItemData { Name = "Eggs", Calories = 155, Protein = 13, Carbs = 1.1, Fat = 11, Price = 3.0, PathwayRecommendation = "Gym" },
        new GroceryItemData { Name = "Greek Yogurt", Calories = 59, Protein = 10, Carbs = 3.6, Fat = 0.4, Price = 4.0, PathwayRecommendation = "Gym" },
        new GroceryItemData { Name = "Whey Protein Powder", Calories = 379, Protein = 78, Carbs = 6, Fat = 3, Price = 35.0, PathwayRecommendation = "Gym" },
        new GroceryItemData { Name = "Electrolyte Powder", Calories = 10, Protein = 0, Carbs = 2, Fat = 0, Price = 15.0, PathwayRecommendation = "Gym" },
        new GroceryItemData { Name = "Salmon", Calories = 208, Protein = 20, Carbs = 0, Fat = 13, Price = 12.0, PathwayRecommendation = "Gym" },
        new GroceryItemData { Name = "Lean Ground Beef", Calories = 250, Protein = 26, Carbs = 0, Fat = 15, Price = 7.5, PathwayRecommendation = "Gym" },
        new GroceryItemData { Name = "Chocolate Milk", Calories = 83, Protein = 3.5, Carbs = 10, Fat = 3.4, Price = 2.5, PathwayRecommendation = "Gym" },

        // Diet Trackers (Low Calorie, Keto, Vegan, Fiber)
        new GroceryItemData { Name = "Lentils", Calories = 116, Protein = 9, Carbs = 20, Fat = 0.4, Price = 2.0, PathwayRecommendation = "Diet" },
        new GroceryItemData { Name = "Broccoli", Calories = 41, Protein = 2.8, Carbs = 7, Fat = 0.3, Price = 1.5, PathwayRecommendation = "Diet" },
