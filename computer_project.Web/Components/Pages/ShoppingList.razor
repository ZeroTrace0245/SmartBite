        new GroceryItemData { Name = "Oatmeal", Calories = 389, Protein = 16.9, Carbs = 66.3, Fat = 6.9, Price = 3.0, PathwayRecommendation = "General" },
        new GroceryItemData { Name = "Bananas", Calories = 89, Protein = 1.1, Carbs = 22.8, Fat = 0.3, Price = 1.5, PathwayRecommendation = "General" },
        new GroceryItemData { Name = "Apples", Calories = 52, Protein = 0.3, Carbs = 14, Fat = 0.2, Price = 2.0, PathwayRecommendation = "General" },
        new GroceryItemData { Name = "Mixed Berries", Calories = 57, Protein = 0.7, Carbs = 14, Fat = 0.3, Price = 4.5, PathwayRecommendation = "General" },
