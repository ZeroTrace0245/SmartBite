@page "/steps"
@using computer_project.Web.Services
@using OpenAI.Chat
@using Microsoft.Extensions.DependencyInjection
@using System.Text.Json
@inject UserSession Session
@inject IJSRuntime JS
@inject IServiceProvider Provider
@rendermode InteractiveServer

<PageTitle>Step Tracker - SmartBite</PageTitle>

<div class="px-md-4 py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <div class="breadcrumb-small mb-1 text-uppercase ls-widest fw-bold opacity-75 text-primary">Wellness Tools</div>
            <h1 class="display-6 fw-bold mb-0">Step Tracking</h1>
        </div>
        <div>
            <button class="btn btn-outline-primary btn-sm rounded-pill px-3" @onclick="GenerateRandomSteps"><i class="bi bi-arrow-clockwise me-1"></i> Refresh Data</button>
        </div>
    </div>

    <div class="card p-4 shadow-sm rounded-4 mb-4 border-0">
        <h5 class="fw-bold mb-3">Smart Step Log with AI</h5>
        <div class="d-flex gap-2 flex-wrap">
            <input class="form-control" style="min-width: 280px;" @bind="activityInput" placeholder="e.g. I ran for 30 min, walked 1KM in 10 min" />
            <button class="btn btn-outline-primary" @onclick="EstimateStepsFromText" disabled="@isEstimatingSteps">
                @if (isEstimatingSteps) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Estimate Steps
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(stepEstimateMessage))
        {
            <p class="small text-muted mt-2 mb-0">@stepEstimateMessage</p>
        }
    </div>

    <!-- Main Score Card -->
    <div class="card p-4 border-3 shadow-sm rounded-4 mb-4 @(isGoodSteps ? "border-success" : "border-danger")">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="text-muted small fw-bold mb-1 text-uppercase ls-wide">Today's Total</div>
                <div class="display-4 fw-bold @(isGoodSteps ? "text-success" : "text-danger") mb-2">
                    @totalSteps.ToString("N0") <span class="h5 text-muted fw-normal">steps</span>
                </div>
                <p class="mb-0 fw-semibold @(isGoodSteps ? "text-success" : "text-danger")">
                    @if (isGoodSteps)
                    {
                        <svg width="20" height="20" class="me-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <span>Goal Achieved! You reached your daily 10,000 steps target.</span>
                    }
                    else
                    {
                        <svg width="20" height="20" class="me-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 16s-1.5-2-4-2-4 2-4 2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                        <span>Keep moving! You are @((10000 - totalSteps).ToString("N0")) steps away from your goal.</span>
                    }
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-4 mt-md-0">
                <div class="d-inline-block text-center bg-light p-3 rounded-4 border">
                    <div class="small fw-bold text-muted mb-1">Average per Hour</div>
                    <div class="h3 fw-bold mb-0">@averageSteps.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hourly Breakdown -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white border-bottom p-4">
            <h5 class="fw-bold mb-0">Hourly Breakdown</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-borderless text-center align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="py-3 text-start ps-4">Time</th>
                            <th class="py-3">Activity Level</th>
                            <th class="py-3 text-end pe-4">Steps Taken</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in hourlySteps)
                        {
                            <tr>
                                <td class="ps-4 text-start fw-bold text-muted">@entry.Time</td>
                                <td>
                                    @if(entry.Steps == 0)
                                    {
                                        <span class="badge bg-secondary opacity-50 px-3 py-1">Resting</span>
                                    }
                                    else if (entry.Steps < 500)
                                    {
                                        <span class="badge bg-light border text-dark px-3 py-1">Light</span>
                                    }
                                    else if (entry.Steps < 1500)
                                    {
                                        <span class="badge bg-info text-dark px-3 py-1">Moderate</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success px-3 py-1">Active</span>
                                    }
                                </td>
                                <td class="pe-4 text-end fw-bold @(entry.Steps > 1500 ? "text-success" : "")">@entry.Steps.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

@code {
    private class AiStepsData
    {
        public int Steps { get; set; }
        public string? ActivitySummary { get; set; }
    }

    private int totalSteps;
    private int averageSteps;
    private bool isGoodSteps;
    private List<HourlyStep> hourlySteps = new();
    private string activityInput = "";
    private bool isEstimatingSteps = false;
    private string stepEstimateMessage = "";

    protected override void OnInitialized()
    {
        GenerateRandomSteps();
    }

    private void GenerateRandomSteps()
    {
        hourlySteps.Clear();
        var random = new Random();
        totalSteps = 0;

        // Generate data for a typical waking day (e.g., 7 AM to 10 PM)
        int startHour = 7;
        int endHour = 22;

        for (int i = startHour; i <= endHour; i++)
        {
            // Injecting logic where middle of the day has more steps 
            int multiplier = (i >= 12 && i <= 18) ? 2 : 1; 

            // occasional high step logic
            var chances = random.Next(1, 100);
            int stepChunk = 0;

            if (chances > 85) stepChunk = random.Next(1500, 3000);   // Heavy walking/workout
            else if (chances > 40) stepChunk = random.Next(200, 1000) * multiplier; // Moderate walking
            else stepChunk = random.Next(0, 150); // Sitting/Idle

            totalSteps += stepChunk;

            var timeStr = new TimeOnly(i, 0).ToString("hh:mm tt");
            hourlySteps.Add(new HourlyStep { Time = timeStr, Steps = stepChunk });
        }

        averageSteps = totalSteps / hourlySteps.Count;
        isGoodSteps = totalSteps >= 10000;
    }

    private async Task EstimateStepsFromText()
    {
        stepEstimateMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(activityInput))
        {
            return;
        }

        var chatClient = Provider.GetService<ChatClient>();
        if (chatClient == null)
        {
            await JS.InvokeVoidAsync("alert", "AI ChatClient not configured. Please add GitHubToken to user secrets.");
            return;
        }

        isEstimatingSteps = true;
        try
        {
            var prompt = $$"""
                You are a fitness activity parser.
                Estimate total steps from this user note:
                "{{activityInput}}"

                Consider common step cadence for walking/running and distance-to-steps conversion where needed.

                Respond ONLY with a valid JSON object matching this schema. Do not include markdown codeblocks or any backticks.
                {
                  "Steps": number (estimated total step count),
                  "ActivitySummary": "string (short summary of how estimate was interpreted)"
                }
                """;

            var response = await chatClient.CompleteChatAsync(prompt);
            var jsonString = response.Value.Content[0].Text?.Trim();

            if (string.IsNullOrWhiteSpace(jsonString))
            {
                stepEstimateMessage = "Could not estimate steps from your text.";
                return;
            }

            if (jsonString.StartsWith("```json"))
            {
                jsonString = jsonString.Substring(7);
                if (jsonString.EndsWith("```")) jsonString = jsonString.Substring(0, jsonString.Length - 3);
            }
            else if (jsonString.StartsWith("```"))
            {
                jsonString = jsonString.Substring(3);
                if (jsonString.EndsWith("```")) jsonString = jsonString.Substring(0, jsonString.Length - 3);
            }

            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var data = JsonSerializer.Deserialize<AiStepsData>(jsonString.Trim(), options);

            if (data == null || data.Steps <= 0)
            {
                stepEstimateMessage = "Could not estimate steps from your text.";
                return;
            }

            hourlySteps.Add(new HourlyStep
            {
                Time = DateTime.Now.ToString("hh:mm tt"),
                Steps = data.Steps
            });

            totalSteps += data.Steps;
            averageSteps = hourlySteps.Count > 0 ? totalSteps / hourlySteps.Count : 0;
            isGoodSteps = totalSteps >= 10000;
            stepEstimateMessage = $"Added {data.Steps:N0} estimated steps. {data.ActivitySummary}";
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Failed to estimate steps: {ex.Message}");
        }
        finally
        {
            isEstimatingSteps = false;
        }
    }

    public class HourlyStep
    {
        public string Time { get; set; } = string.Empty;
        public int Steps { get; set; }
    }
}
